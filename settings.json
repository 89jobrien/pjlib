{
  "cleanupPeriodDays": 30,
  "env": {
    "CLOUD_ML_REGION": "global",
    "CLOUDSDK_ACTIVE_CONFIG_NAME": "toptal-agent-ops",
    "CLAUDE_CODE_USE_VERTEX": "1",
    "MAESTRO_COMPANION_WS": "ws://localhost:8765",
    "MAESTRO_COMPANION_DEBUG": "0",
    "BAML_LOG": "info",
    "BOUNDARY_MAX_LOG_CHUNK_CHARS": "3000",
    "MCP_ENV_FILE": "/Users/joe/.config/dev-bootstrap/secrets.env"
  },
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [
      "Bash(brew install:*)",
      "Bash(brew tap:*)",
      "Bash(mkdir:*)",
      "Bash(vector validate:*)",
      "Bash(~/logs/applications/test.log)",
      "Bash(~/logs/scripts/script.log)",
      "Bash(tree ~/.claude:*)",
      "Bash(tree ~/Documents/Projects:*)",
      "Bash(tree ./:*)",
      "Bash(stow:*)",
      "Bash(test:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:www.anthropic.com)",
      "WebFetch(domain:openai.com)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:hn.algolia.com)",
      "WebFetch(domain:news.ycombinator.com)",
      "WebFetch(domain:dev.to)",
      "WebFetch(domain:www.reddit.com)",
      "WebFetch(domain:livekit.io)",
      "WebFetch(domain:docs.openpipe.ai)",
      "Bash(opencode:*)",
      "Bash(uvx:*)",
      "Bash(uv run:*)",
      "Bash(uv sync:*)",
      "Bash(uv lock:*)",
      "Bash(uv add:*)",
      "Bash(uv remove:*)",
      "Bash(uv update:*)",
      "Bash(ls:*)",
      "Bash(cargo:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(jira:*)",
      "Bash(acli:*)"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "acceptEdits"
  },
  "enabledMcpjsonServers": [],
  "disabledMcpjsonServers": [
    "memory",
    "context7",
    "fetch"
  ],
  "statusLine": {
    "type": "command",
    "command": "bash -c '\"/Users/joe/.bun/bin/bun\" \"$(ls -td ~/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1)src/index.ts\"'"
  },
  "enabledPlugins": {
    "agent-sdk-dev@claude-plugins-official": false,
    "asana@claude-plugins-official": false,
    "atlassian@claude-plugins-official": false,
    "claude-mem@thedotmack": true,
    "code-review@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": false,
    "gopls-lsp@claude-plugins-official": true,
    "gopls@claude-code-lsps": false,
    "greptile@claude-plugins-official": false,
    "linear@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": false,
    "pyright-lsp@claude-plugins-official": true,
    "pyright@claude-code-lsps": false,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": false,
    "claude-hud@claude-hud": true,
    "context7@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true,
    "individual-jobrien@toptal-agent-playbooks": true,
    "rust-analyzer@claude-code-lsps": true,
    "typescript-lsp@claude-plugins-official": true,
    "semgrep@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "review-loop@hamel-review": true
  },
  "skipDangerousModePermissionPrompt": true
}
