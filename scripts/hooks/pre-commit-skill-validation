#!/bin/bash
# Pre-commit hook for validating SKILL.md files
# Install: ln -sf ../../scripts/hooks/pre-commit-skill-validation .git/hooks/pre-commit

set -e

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Check if any SKILL.md files are being committed
SKILL_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep 'SKILL\.md$' || true)

if [ -z "$SKILL_FILES" ]; then
    # No SKILL.md files in this commit
    exit 0
fi

echo -e "${YELLOW}Validating SKILL.md files...${NC}"

# Get the repository root
REPO_ROOT=$(git rev-parse --show-toplevel)

# Create temp directory for staged files
TEMP_DIR=$(mktemp -d)
trap "rm -rf $TEMP_DIR" EXIT

# Copy staged SKILL.md files to temp directory preserving structure
for file in $SKILL_FILES; do
    mkdir -p "$TEMP_DIR/$(dirname $file)"
    git show ":$file" > "$TEMP_DIR/$file"
done

# Run validation on staged files only
cd "$REPO_ROOT"

# Find the closest skills directory
if [ -d "skills" ]; then
    SKILLS_DIR="$TEMP_DIR/skills"
elif [ -d ".claude/skills" ]; then
    SKILLS_DIR="$TEMP_DIR/.claude/skills"
else
    echo -e "${YELLOW}Warning: No skills directory found, skipping validation${NC}"
    exit 0
fi

# Check if validation script exists
VALIDATOR="$REPO_ROOT/.claude/scripts/validate-skills.py"
if [ ! -f "$VALIDATOR" ]; then
    VALIDATOR="$HOME/.claude/scripts/validate-skills.py"
fi

if [ ! -f "$VALIDATOR" ]; then
    echo -e "${YELLOW}Warning: validate-skills.py not found, skipping validation${NC}"
    exit 0
fi

# Run validation
echo "Checking staged SKILL.md files:"
for file in $SKILL_FILES; do
    echo "  - $file"
done
echo ""

# Run validator (capture output to check for errors)
if OUTPUT=$("$VALIDATOR" "$SKILLS_DIR" 2>&1); then
    echo -e "${GREEN}✅ All SKILL.md files are valid${NC}"
    exit 0
else
    echo "$OUTPUT"

    # Check if there are errors (not just warnings)
    if echo "$OUTPUT" | grep -q "❌ ERRORS"; then
        echo ""
        echo -e "${RED}❌ SKILL.md validation failed${NC}"
        echo -e "${RED}Please fix the errors above before committing${NC}"
        echo ""
        echo "To bypass this check (not recommended):"
        echo "  git commit --no-verify"
        exit 1
    else
        echo ""
        echo -e "${YELLOW}⚠️  SKILL.md files have warnings (committing anyway)${NC}"
        exit 0
    fi
fi
